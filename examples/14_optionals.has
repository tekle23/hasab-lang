// 14 - Null Handling
// Demonstrates nil, optional types, and null assertion.

fn find_value(x: int) -> int {
    if x == 42 {
        return 42;
    }
    return 0;
}

fn main() {
    let maybe_number = find_value(42);
    println(maybe_number);

    let name = "HASAB";
    let len_name = len(name);
    println(len_name);
}
