// 02 - Variables and Types
// Demonstrates immutable/mutable variables and basic types.

fn main() {
    let x = 42;
    let pi = 3.14159;
    let active = true;
    let g = 'A';

    println(x);
    println(pi);
    println(active);
    println(g);

    let mut counter = 0;
    counter += 1;
    counter += 1;
    println(counter);

    let name = "HASAB";
    let greeting = "Language: " + name;
    println(greeting);
}
